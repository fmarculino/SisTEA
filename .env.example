# Supabase Client Credentials
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Optional: Supabase Client Publishable Key (if used in some client libs)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Server-side Administrative Credentials
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Security & Sessions
VALIDATION_HMAC_SECRET=your_32_character_hex_secret

# Database Direct Connection (used for migrations or direct queries)
DATABASE_URL=postgresql://postgres:password@db_host:5432/postgres
